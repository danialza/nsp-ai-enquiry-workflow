# LLM provider abstraction (only openai is implemented in this prototype)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=45

# Required for LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Optional: defaults to output/example_output.json
OUTPUT_PATH=output/example_output.json
